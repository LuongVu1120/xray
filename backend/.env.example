# Sao chép thành .env local hoặc dán vào bảng Variables trên Railway
DEMO_MODE=false
MODEL_PATH=saved_model/xray_model.h5
GDRIVE_FILE_ID=
MODEL_TYPE=auto
# Domain tùy chỉnh (Vercel custom domain) — bắt buộc thêm; *.vercel.app đã khớp qua regex trong code
ALLOWED_ORIGINS=https://your-frontend.vercel.app
