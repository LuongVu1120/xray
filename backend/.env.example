# ── Cấu hình model ──────────────────────────────────────
DEMO_MODE=false
MODEL_PATH=saved_model/xray_model.h5
GDRIVE_FILE_ID=
MODEL_TYPE=auto
# Render free thiếu RAM: thử TF_LOW_MEMORY=true hoặc DEMO_MODE=true hoặc TFLite + MODEL_TYPE=tflite
TF_LOW_MEMORY=true

# ── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── LLM agent (tuỳ chọn) ────────────────────────────────
# Nếu trống, /agent/diagnose tự fallback template (vẫn chạy được).
# Free options: Groq (https://console.groq.com), Cerebras, OpenRouter.
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_S=60
