# Sao chép thành .env local hoặc dán vào bảng Variables (Railway / Render)
DEMO_MODE=false
MODEL_PATH=saved_model/xray_model.h5
GDRIVE_FILE_ID=
MODEL_TYPE=auto
# Render free thiếu RAM: thử TF_LOW_MEMORY=true hoặc DEMO_MODE=true hoặc TFLite + MODEL_TYPE=tflite
TF_LOW_MEMORY=true
ALLOWED_ORIGINS=https://your-frontend.vercel.app
